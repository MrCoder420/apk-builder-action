name: React Native APK Build
on:
  workflow_dispatch:
    inputs:
      repo_url:
        description: 'Git repository URL'
        required: true
        default: 'https://github.com/priyanshusharma99/SoulShuffle'

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      
      - name: Clone Target Repo
        run: git clone ${{ github.event.inputs.repo_url }} target-app

      - name: Install Node.js
        uses: actions/setup-node@v3
        with:
          node-version: 18

      - name: Install NPM Dependencies
        run: |
          cd target-app
          npm install --legacy-peer-deps

      - name: Set up JDK 17
        uses: actions/setup-java@v3
        with:
          java-version: '17'
          distribution: 'temurin'

      - name: Build Android Release
        run: |
          cd target-app/android
          chmod +x gradlew
          ./gradlew assembleRelease

      - name: Upload APK
        uses: actions/upload-artifact@v3
        with:
          name: soulshuffle-apk
          path: target-app/android/app/build/outputs/apk/release/*.apk

